{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT \n            u.id, \n            u.suspended,\n            f.new_file_name || '.' || f.extension AS image_name\n            FROM users u\n            JOIN files f ON u.image_id = f.Id\n            WHERE u.is_admin = false\n            AND u.id = $1\n            ",
